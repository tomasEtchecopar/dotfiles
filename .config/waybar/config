{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,

    "modules-left": [
        "hyprland/workspaces",
        "custom/cava",
        "custom/cpu",
        "custom/gpu-temp",
    ],

    "modules-center": [
        "hyprland/window"
    ],

    "modules-right": [
        "memory",
        "network",
        "wireplumber",
        "clock",
        "tray"
    ],

"hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
        "1": "ґ░ЖН",
        "2": "ґ░И╣",
        "3": "ґ░В╜",
        "4": "ґ░ЭЪ",
        "5": "ґ░КЧ",
        "6": "ґ░Щп",
        "10": "ґ░Н╣",
        "urgent": "ґ░ЧЦ",
        "default": "ґ░Ка"
    },
    "persistent-workspaces": {},
    "show-special": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
},

    "hyprland/window": {
        "format": "{}",
        "max-length": 50
    },

    "custom/cava": {
        "exec": "sleep 1 && cava -p ~/.config/cava/waybar.ini | sed -u 's/;//g;s/0/тЦБ/g;s/1/тЦВ/g;s/2/тЦГ/g;s/3/тЦД/g;s/4/тЦЕ/g;s/5/тЦЖ/g;s/6/тЦЗ/g;s/7/тЦИ/g'",
        "format": "{}",
        "tooltip": false
    },

"custom/gpu-temp": {
    "exec": "nvidia-smi --query-gpu=temperature.gpu,utilization.gpu --format=csv,noheader,nounits | awk -F', ' '{print \"GPU: \"$2\"%  \"$1\"┬░\"}'",
    "interval": 2,
    "format": "{}",
    "tooltip": false
},

"temperature": {
    "thermal-zone": 0,
    "critical-threshold": 80,
    "format": "{temperatureC}┬░",
    "format-critical": "{temperatureC}┬░ !"
},

"cpu": {
    "interval": 2,
    "format": "CPU: {usage}%",
    "max-length": 10
},
"custom/cpu": {
    "exec": "cpu_usage=$(top -bn1 | grep 'Cpu(s)' | awk '{print $2}') && cpu_temp=$(sensors k10temp-pci-00c3 | grep 'Tctl' | awk '{print $2}' | tr -d '+┬░C') && echo \"CPU: ${cpu_usage}%  ${cpu_temp}┬░\"",
    "interval": 2,
    "format": "{}",
    "tooltip": false
},
"memory": {
        "interval": 5,
        "format": "RAM: {used:0.1f}G/{total:0.1f}G"
    },

    "network": {
        "interval": 2,
        "format-wifi": " {signalStrength}%",
"format-ethernet": "тЖУ {bandwidthDownBytes} тЖС {bandwidthUpBytes}",
        "format-disconnected": "тЬЧ",
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "wireplumber": {
        "format": " {volume}%",
        "format-muted": " muted",
        "on-click": "pavucontrol"
    },

    "clock": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "timezone": "America/Argentina/Buenos_Aires",
    },

    "tray": {
        "spacing": 10
    }
}
